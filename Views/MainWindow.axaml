<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NullWave.ViewModels"
        xmlns:models="using:NullWave.Models"
        x:Class="NullWave.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="NullWave"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        Background="#1a1a2e">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel Margin="16">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="🎵 NullWave"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#e94560"
                   Margin="0,0,0,16"/>

        <!-- Input Panel -->
        <Border DockPanel.Dock="Top"
                Background="#16213e"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel Spacing="8">

                <TextBox Text="{Binding InputUrl}"
                         PlaceholderText="Paste URL (YouTube, Spotify...)"
                         Background="#0f3460"
                         Foreground="White"
                         CornerRadius="4"/>

                <Grid ColumnDefinitions="*,*,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding InputTitle}"
                             PlaceholderText="Title *"
                             Background="#0f3460"
                             Foreground="White"
                             CornerRadius="4"
                             Margin="0,0,8,0"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding InputArtist}"
                             PlaceholderText="Artist"
                             Background="#0f3460"
                             Foreground="White"
                             CornerRadius="4"
                             Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding SourceOptions}"
                              SelectedItem="{Binding SelectedSource}"
                              Background="#0f3460"
                              Foreground="White"
                              Margin="0,0,8,0"/>

                    <Button Grid.Column="3"
                            Content="Add Track"
                            Command="{Binding AddTrackCommand}"
                            Background="#e94560"
                            Foreground="White"
                            CornerRadius="4"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search Bar -->
        <TextBox DockPanel.Dock="Top"
                 Text="{Binding SearchQuery}"
                 PlaceholderText="🔍 Search by title or artist..."
                 Background="#16213e"
                 Foreground="White"
                 CornerRadius="4"
                 Margin="0,0,0,12"/>

        <!-- Bottom Bar -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Tracks.Count, StringFormat='📦 {0} tracks in library'}"
                           Foreground="#666"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Remove Selected"
                        Command="{Binding RemoveTrackCommand}"
                        Background="#333"
                        Foreground="#e94560"
                        CornerRadius="4"/>
            </Grid>
        </Border>

        <!-- Track List -->
        <Border Background="#16213e"
                CornerRadius="8"
                Padding="8">
            <DockPanel>

                <!-- List Header -->
                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="*,*,120,140"
                      Margin="8,4">
                    <TextBlock Grid.Column="0" Text="Title" Foreground="#888" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Artist" Foreground="#888" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Source" Foreground="#888" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Date Added" Foreground="#888" FontWeight="Bold"/>
                </Grid>

                <ListBox ItemsSource="{Binding Tracks}"
                         SelectedItem="{Binding SelectedTrack}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Track">
                            <Grid ColumnDefinitions="*,*,120,140" Margin="0,4">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Title}"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Artist}"
                                           Foreground="#aaa"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Source}"
                                           Foreground="#e94560"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding DateAdded, StringFormat='{}{0:MMM dd, yyyy}'}"
                                           Foreground="#666"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>