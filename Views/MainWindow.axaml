<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NullWave.ViewModels"
        xmlns:models="using:NullWave.Models"
        xmlns:helpers="using:NullWave.Helpers"
        x:Class="NullWave.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="NullWave"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#111118">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Styles>

        <!-- Sidebar nav button -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a1a3e"/>
            <Setter Property="TextElement.Foreground" Value="#c084fc"/>
        </Style>

        <!-- Track row selection -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1a1a2e"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a1a3e"/>
        </Style>

        <!-- Icon button -->
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <!-- Tag chip -->
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="#2a1a3e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <!-- Primary button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7c3aed"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#6d28d9"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#3a0a1a"/>
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Input -->
        <Style Selector="TextBox.input">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2a2a3e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </Window.Styles>

    <Window.Resources>
        <helpers:BoolToOpacityConverter x:Key="BoolToOpacity"/>
    </Window.Resources>

    <DockPanel>

        <!-- ── Menu Bar ── -->
        <Menu DockPanel.Dock="Top"
              Background="#0a0a12"
              Foreground="#aaa"
              Padding="4,2">

            <MenuItem Header="File" Foreground="#aaa">
                <MenuItem Header="➕  Add Track"
                          Command="{Binding Input.AddTrackCommand}"/>
                <MenuItem Header="📂  Add Local File"
                          Command="{Binding Input.AddLocalFileCommand}"/>
                <MenuItem Header="📁  Import Folder"
                          Command="{Binding Import.ImportFolderCommand}"/>
                <Separator/>
                <MenuItem Header="💾  Export as JSON"
                          Command="{Binding Export.ExportJsonCommand}"/>
                <MenuItem Header="💾  Export as CSV"
                          Command="{Binding Export.ExportCsvCommand}"/>
                <Separator/>
                <MenuItem Header="✖  Exit"
                          Command="{Binding ExitCommand}"/>
            </MenuItem>

            <MenuItem Header="Library" Foreground="#aaa">
                <MenuItem Header="✖  Clear Search"
                          Command="{Binding Library.ClearSearchCommand}"/>
                <Separator/>
                <MenuItem Header="Sort by Title"
                          Command="{Binding Library.SortByTitleCommand}"/>
                <MenuItem Header="Sort by Artist"
                          Command="{Binding Library.SortByArtistCommand}"/>
                <MenuItem Header="Sort by Date Added"
                          Command="{Binding Library.SortByDateCommand}"/>
                <MenuItem Header="Sort by Play Count"
                          Command="{Binding Library.SortByPlayCountCommand}"/>
            </MenuItem>

            <MenuItem Header="Settings" Foreground="#aaa">
                <MenuItem Header="⚙  Open Settings"
                          Command="{Binding OpenSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="🗑  Delete API Keys"
                          Command="{Binding Settings.DeleteApiKeysCommand}"/>
                <MenuItem Header="🗑  Delete Logs"
                          Command="{Binding Settings.DeleteLogsCommand}"/>
                <Separator/>
                <MenuItem Header="⚠  Wipe Everything"
                          Command="{Binding Settings.DeleteEverythingCommand}"/>
            </MenuItem>

            <MenuItem Header="Help" Foreground="#aaa">
                <MenuItem Header="📋  About NullWave"
                          Command="{Binding AboutCommand}"/>
                <MenuItem Header="📁  Open Data Folder"
                          Command="{Binding OpenDataFolderCommand}"/>
                <MenuItem Header="📜  View Logs"
                          Command="{Binding OpenLogsCommand}"/>
            </MenuItem>

        </Menu>

        <!-- ── Mini Player Bar ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#0a0a12"
                BorderBrush="#1e1e2e"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <Button Grid.Column="0"
                        Classes="icon"
                        Content="{Binding Player.PlayPauseIcon}"
                        Command="{Binding Player.PlayPauseCommand}"
                        FontSize="16"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Classes="icon"
                        Content="⏹"
                        Command="{Binding Player.StopCommand}"
                        FontSize="14"
                        Margin="0,0,12,0"/>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Spacing="1">
                    <TextBlock Text="{Binding Player.CurrentTrackDisplay}"
                               Foreground="White"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Player.StatusText}"
                               Foreground="#555"
                               FontSize="10"/>
                </StackPanel>

                <TextBlock Grid.Column="3"
                           Text="{Binding Player.PositionDisplay}"
                           Foreground="#555"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="12,0"/>

                <ProgressBar Grid.Column="4"
                             Value="{Binding Player.DownloadProgress}"
                             Maximum="1"
                             Width="80"
                             Height="3"
                             IsVisible="{Binding Player.IsDownloading}"
                             Foreground="#7c3aed"
                             Background="#1e1e2e"
                             VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main Area ── -->
        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- ── Left Sidebar ── -->
            <Border Grid.Column="0"
                    Background="#0a0a12"
                    BorderBrush="#1e1e2e"
                    BorderThickness="0,0,1,0"
                    Width="200"
                    Padding="8,12">
                <DockPanel>

                    <StackPanel DockPanel.Dock="Top"
                                Margin="8,0,0,16">
                        <TextBlock Text="🎵 NullWave"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"/>
                        <TextBlock Text="music organizer"
                                   Foreground="#444"
                                   FontSize="10"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Spacing="2">

                        <TextBlock Text="LIBRARY"
                                   Foreground="#333"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="10,0,0,6"
                                   LetterSpacing="2"/>

                        <Button Content="🎵  Library"
                                Classes="nav active"
                                Command="{Binding NavigateLibraryCommand}"/>
                        <Button Content="📋  Playlists"
                                Classes="nav"
                                Command="{Binding NavigatePlaylistsCommand}"/>
                        <Button Content="🎶  Queue"
                                Classes="nav"
                                Command="{Binding NavigateQueueCommand}"/>
                        <Button Content="📊  Stats"
                                Classes="nav"
                                Command="{Binding NavigateStatsCommand}"/>

                        <TextBlock Text="FILTERS"
                                   Foreground="#333"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="10,16,0,6"
                                   LetterSpacing="2"/>

                        <Button Content="⭐  Favorites"
                                Classes="nav"
                                Command="{Binding Library.ShowFavoritesCommand}"/>
                        <Button Content="🕐  Recent"
                                Classes="nav"
                                Command="{Binding Library.ShowRecentCommand}"/>

                        <TextBlock Text="SOURCES"
                                   Foreground="#333"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="10,16,0,6"
                                   LetterSpacing="2"/>

                        <Button Content="▶  YouTube"
                                Classes="nav"
                                Command="{Binding Library.FilterYouTubeCommand}"/>
                        <Button Content="♪  Spotify"
                                Classes="nav"
                                Command="{Binding Library.FilterSpotifyCommand}"/>
                        <Button Content="◎  Last.fm"
                                Classes="nav"
                                Command="{Binding Library.FilterLastFmCommand}"/>
                        <Button Content="☁  SoundCloud"
                                Classes="nav"
                                Command="{Binding Library.FilterSoundCloudCommand}"/>
                        <Button Content="💾  Local"
                                Classes="nav"
                                Command="{Binding Library.FilterLocalCommand}"/>

                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding Library.Tracks.Count, StringFormat='📦 {0} tracks'}"
                               Foreground="#333"
                               FontSize="10"
                               Margin="10,0"/>

                </DockPanel>
            </Border>

            <!-- ── Center: Track List ── -->
            <DockPanel Grid.Column="1">

                <!-- Search + Sort bar -->
                <Border DockPanel.Dock="Top"
                        Background="#0d0d18"
                        Padding="16,10"
                        BorderBrush="#1e1e2e"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0"
                                 Classes="input"
                                 Text="{Binding Library.SearchQuery, Mode=TwoWay}"
                                 PlaceholderText="🔍  Search tracks..."
                                 Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Library.SortOptions}"
                                  SelectedItem="{Binding Library.CurrentSort}"
                                  Background="#1a1a2e"
                                  Foreground="White"
                                  BorderBrush="#2a2a3e"
                                  Margin="0,0,10,0"
                                  MinWidth="130"/>
                        <Button Grid.Column="2"
                                Content="🗑  Remove"
                                Classes="danger"
                                Command="{Binding Library.RemoveTrackCommand}"/>
                    </Grid>
                </Border>

                <!-- Import progress -->
                <Border DockPanel.Dock="Top"
                        Background="#0d1a0d"
                        Padding="16,8"
                        IsVisible="{Binding Import.IsImporting}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Import.ImportStatus}"
                                   Foreground="#4ade80"
                                   FontSize="12"/>
                        <ProgressBar Value="{Binding Import.ImportProgress}"
                                     Maximum="{Binding Import.ImportTotal}"
                                     Height="4"
                                     Foreground="#4ade80"
                                     Background="#1a2a1a"/>
                    </StackPanel>
                </Border>

                <!-- Column headers -->
                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="24,*,160,90,110,32,32"
                      Margin="16,8,16,4">
                    <TextBlock Grid.Column="1" Text="TITLE / ARTIST"
                               Foreground="#333" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="2" Text="SOURCE"
                               Foreground="#333" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="3" Text="PLAYS"
                               Foreground="#333" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="4" Text="ADDED"
                               Foreground="#333" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                </Grid>

                <!-- Track List -->
                <ListBox ItemsSource="{Binding Library.Tracks}"
                         SelectedItem="{Binding Library.SelectedTrack}"
                         Background="Transparent"
                         Margin="8,0,8,8"
                         SelectionChanged="OnTrackSelected">

                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="ContextMenu">
                                <ContextMenu>
                                    <MenuItem Header="▶  Play"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.PlayTrackCommand}"
                                              CommandParameter="{Binding $parent[ListBoxItem].Content}"/>
                                    <MenuItem Header="🔍  View Details"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.OpenDetailCommand}"/>
                                    <MenuItem Header="⭐  Toggle Favorite"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.ToggleFavoriteCommand}"/>
                                    <MenuItem Header="🎶  Add to Queue"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.AddToQueueCommand}"/>
                                    <MenuItem Header="🔗  Copy URL"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.CopyUrlCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="🗑  Remove"
                                              Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.RemoveTrackCommand}"/>
                                </ContextMenu>
                            </Setter>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Track">
                            <Grid ColumnDefinitions="24,*,160,90,110,32,32"
                                  Margin="8,4">

                                <!-- Favorite indicator -->
                                <TextBlock Grid.Column="0"
                                           Text="⭐"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="#f59e0b"
                                           Opacity="{Binding IsFavorite, Converter={StaticResource BoolToOpacity}}"/>

                                <!-- Title + Artist -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="1">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist}"
                                               Foreground="#666"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Source -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Source}"
                                           Foreground="#7c3aed"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>

                                <!-- Play count -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding PlayCount}"
                                           Foreground="#555"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>

                                <!-- Date added -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding DateAdded, StringFormat='{}{0:MMM dd, yyyy}'}"
                                           Foreground="#444"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>

                                <!-- Favorite toggle -->
                                <Button Grid.Column="5"
                                        Classes="icon"
                                        Content="⭐"
                                        Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.ToggleFavoriteCommand}"
                                        ToolTip.Tip="Toggle Favorite"/>

                                <!-- Three-dot menu -->
                                <Button Grid.Column="6"
                                        Classes="icon"
                                        Content="⋮"
                                        ToolTip.Tip="More options">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuItem Header="▶  Play"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.PlayTrackCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="🔍  View Details"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.OpenDetailCommand}"/>
                                            <MenuItem Header="⭐  Toggle Favorite"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.ToggleFavoriteCommand}"/>
                                            <MenuItem Header="🎶  Add to Queue"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.AddToQueueCommand}"/>
                                            <MenuItem Header="🔗  Copy URL"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.CopyUrlCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="🗑  Remove"
                                                      Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).Library.RemoveTrackCommand}"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>

                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>

            <!-- ── Right: Detail Panel ── -->
            <Border Grid.Column="2"
                    Background="#0d0d18"
                    BorderBrush="#1e1e2e"
                    BorderThickness="1,0,0,0"
                    Width="{Binding Detail.PanelWidth}"
                    ClipToBounds="True">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Width" Duration="0:0:0.2"/>
                    </Transitions>
                </Border.Transitions>

                <ScrollViewer Padding="16"
                              IsVisible="{Binding Detail.IsOpen}">
                    <StackPanel Spacing="16" Width="280">

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Track Details"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Classes="icon"
                                    Content="✕"
                                    Command="{Binding Detail.CloseCommand}"/>
                        </Grid>

                        <Separator Background="#1e1e2e"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="TITLE" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBox Classes="input" Text="{Binding Detail.EditTitle, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="ARTIST" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBox Classes="input" Text="{Binding Detail.EditArtist, Mode=TwoWay}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="SOURCE" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock Text="{Binding Detail.DisplaySource}" Foreground="#7c3aed" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="icon"
                                    Content="⭐"
                                    FontSize="18"
                                    Command="{Binding Detail.ToggleFavoriteCommand}"
                                    ToolTip.Tip="Toggle Favorite"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="PLAYS" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock Text="{Binding Detail.DisplayPlayCount}" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="LAST PLAYED" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock Text="{Binding Detail.DisplayLastPlayed}" Foreground="White" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="2">
                            <TextBlock Text="DATE ADDED" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBlock Text="{Binding Detail.DisplayDateAdded}" Foreground="White" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="URL / PATH" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBlock Text="{Binding Detail.DisplayUrl}"
                                       Foreground="#7c3aed"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                            <Button Content="🔗  Copy"
                                    Classes="icon"
                                    Command="{Binding Detail.CopyUrlCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Separator Background="#1e1e2e"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="TAGS" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <ItemsControl ItemsSource="{Binding Detail.Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="tag" Margin="0,0,4,4">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#c084fc"
                                                           FontSize="11"/>
                                                <Button Classes="icon"
                                                        Content="✕"
                                                        FontSize="9"
                                                        Padding="2"
                                                        Command="{Binding $parent[ItemsControl].((vm:TrackDetailViewModel)DataContext).RemoveTagCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Classes="input"
                                         Text="{Binding Detail.NewTag, Mode=TwoWay}"
                                         PlaceholderText="Add tag..."
                                         Margin="0,0,6,0"/>
                                <Button Grid.Column="1"
                                        Classes="primary"
                                        Content="+"
                                        Command="{Binding Detail.AddTagCommand}"
                                        Padding="10,7"/>
                            </Grid>
                        </StackPanel>

                        <Separator Background="#1e1e2e"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="NOTES" Foreground="#444" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBox Classes="input"
                                     Text="{Binding Detail.EditNotes, Mode=TwoWay}"
                                     PlaceholderText="Add notes..."
                                     AcceptsReturn="True"
                                     Height="80"/>
                        </StackPanel>

                        <Button Content="💾  Save Changes"
                                Classes="primary"
                                Command="{Binding Detail.SaveCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- ── Floating Add Button ── -->
        <Panel>
            <Button Content="＋"
                    Classes="primary"
                    Command="{Binding Input.AddTrackCommand}"
                    Width="48" Height="48"
                    CornerRadius="24"
                    FontSize="22"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,24"
                    ToolTip.Tip="Add Track"
                    ZIndex="10"/>
        </Panel>

    </DockPanel>
</Window>